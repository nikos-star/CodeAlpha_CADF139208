<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Modern Image Gallery</title>
    <link rel="stylesheet" href="style.css">
</head>
<body>

    <div class="container">
        <h1>Photo Gallery</h1>
        
        <div class="filter-wrapper">
            <button class="filter-btn active" data-filter="all">All</button>
            <button class="filter-btn" data-filter="nature">Nature</button>
            <button class="filter-btn" data-filter="city">City</button>
            <button class="filter-btn" data-filter="animals">Animals</button>
        </div>

        <div class="gallery-grid" id="gallery">
            <div class="gallery-item" data-category="nature">
                <img src="https://picsum.photos/id/10/600/400" alt="Nature">
            </div>
            <div class="gallery-item" data-category="city">
                <img src="https://picsum.photos/id/103/600/400" alt="City">
            </div>
            <div class="gallery-item" data-category="animals">
                <img src="https://picsum.photos/id/237/600/400" alt="Animals">
            </div>
            </div>
    </div>

    <div class="lightbox" id="lightbox">
        <span class="close-btn">&times;</span>
        <button class="nav-btn prev-btn">&#10094;</button>
        <div class="lightbox-content">
            <img src="" id="lightbox-img">
        </div>
        <button class="nav-btn next-btn">&#10095;</button>
    </div>

    <script src="script.js"></script>
</body>
</html>
